generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Article {
  id                 String   @id @default(cuid())
  title              String
  slug               String   @unique
  content            String   @db.LongText
  excerpt            String?
  imageUrl           String?
  category           String
  language           String
  translationGroupId String?
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([translationGroupId])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

/** Manually curated market ticker items shown on the homepage. */
model TickerItem {
  id            String   @id @default(cuid())
  label         String
  price         Float
  currency      String   @default("INR")
  unit          String   @default("kg")
  changePercent Float?
  direction     String   @default("neutral")
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  /// Admin-controlled timestamp (not auto-updated).
  updatedAt     DateTime
  createdAt     DateTime @default(now())
}

/** Singleton row for the ticker "Last Updated" label. */
model TickerMeta {
  id          String   @id @default("default")
  lastUpdated DateTime
}