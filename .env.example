# Leave blank to use the built-in demo market data. Set this to a public,
# CORS-enabled endpoint when the live market API is ready.
NEXT_PUBLIC_MARKET_DATA_API_URL=

# Prisma 7 CLI connection string (server only — never use NEXT_PUBLIC_).
DATABASE_URL=mysql://DATABASE_USER:DATABASE_PASSWORD@DATABASE_HOST:3306/DATABASE_NAME

# Prisma 7 MariaDB driver adapter settings used by the Next.js runtime.
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_CONNECTION_LIMIT=3
DATABASE_CONNECT_TIMEOUT_MS=10000

# Admin authentication (server only).
# Generate a session secret with at least 32 characters, for example:
#   openssl rand -base64 48
ADMIN_SESSION_SECRET=
# Alias accepted by the app if ADMIN_SESSION_SECRET is unset:
AUTH_SECRET=
ADMIN_EMAIL=
# Store a bcrypt hash, never a plain password.
ADMIN_PASSWORD_HASH=
# Optional display name shown in the admin dashboard.
ADMIN_NAME=Shrimp.News Admin
# Optional one-time input for npm run admin:create; do not commit a real value.
ADMIN_BOOTSTRAP_PASSWORD=

# Featured image upload (required locally and on Vercel).
# Both values are server-only. Do not create NEXT_PUBLIC_ copies.
HOSTINGER_UPLOAD_ENDPOINT=https://lightsalmon-salamander-813298.hostingersite.com/api/upload-image.php
# Must exactly match the secret configured in hostinger/upload-image.php.
HOSTINGER_UPLOAD_SECRET=
