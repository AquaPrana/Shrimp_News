# Leave blank to use the built-in demo market data. Set this to a public,
# CORS-enabled endpoint when the live market API is ready.
NEXT_PUBLIC_MARKET_DATA_API_URL=

# Prisma 7 CLI connection string (server only).
DATABASE_URL=mysql://DATABASE_USER:DATABASE_PASSWORD@DATABASE_HOST:3306/DATABASE_NAME
# Prisma 7 MariaDB driver adapter settings used by the Next.js runtime.
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_CONNECTION_LIMIT=3
DATABASE_CONNECT_TIMEOUT_MS=10000

# Hostinger MySQL (server only; never prefix these with NEXT_PUBLIC_)
# Leave false until the Hostinger database and all secrets are ready.
MYSQL_INTEGRATION_ENABLED=false
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
# Set false only when the Hostinger connection does not support TLS.
MYSQL_SSL=true

# Generate at least 32 random bytes, for example: openssl rand -base64 48
ADMIN_SESSION_SECRET=
# Admin login credentials (server only). Store a bcrypt hash, never a plain password.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# Optional display name shown in the admin dashboard.
ADMIN_NAME=Shrimp.News Admin
# Optional one-time input for npm run admin:create; do not commit a real value.
ADMIN_BOOTSTRAP_PASSWORD=
